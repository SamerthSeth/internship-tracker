# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./tracker.db

# JWT Configuration
SECRET_KEY=dev-secret-key-not-for-production-change-this-in-production-must-be-32-chars-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
APP_NAME=Smart Internship & Certificate Tracker
DEBUG=True
ENVIRONMENT=development

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png
FILE_UPLOAD_DIRECTORY=uploads

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
